# Sample credentials file — points MCP bridge at the mock FortiGate shipped
# in this repo (scripts/mock-fortigate.py).
#
# HOW TO USE
#   1. Start the mock:     python scripts/mock-fortigate.py
#   2. Copy this file to your credential directory and REMOVE the .example:
#        Linux/Mac:  cp scripts/sample_credentials.yaml.example ~/.config/mcp/mock_credentials.yaml
#        Windows:    copy scripts\sample_credentials.yaml.example %USERPROFILE%\.config\mcp\mock_credentials.yaml
#   3. Restart your AI editor so the MCP bridge picks it up.
#   4. Ask your editor to call fortigate-health-check against 127.0.0.1.
#
# WHY THE `.example` SUFFIX
#   The repo's .gitignore blocks `*_credentials.yaml` so you can't accidentally
#   commit a real API token. This file is safe to ship because its extension
#   is `.yaml.example`, not `.yaml`.
#
# WHEN YOU HAVE A REAL DEVICE
#   Create a new file next to this one (e.g. fortigate_credentials.yaml),
#   replace the block below with real host + api_token, and remove the mock
#   entry. The bridge will read every *_credentials.yaml in the directory.

devices:
  mock-fortigate:
    host: "127.0.0.1"
    port: 8443
    api_token: "mock-token-not-validated-by-stub"
    verify_ssl: false
    # The mock speaks plain HTTP on 8443 (not HTTPS). Some tools may need
    # a `scheme: http` override — check the tool's Skills.md if it fails.

default_lookup:
  "127.0.0.1": "mock-fortigate"
