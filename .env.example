# MCP Trust Anchor — Example environment file
#
# Copy to .env and edit if you want to change defaults:
#     cp .env.example .env
#
# These values are consumed by docker-compose.yml and by the server when run
# natively via server/install.sh (the installer writes its own file at
# /etc/trust-anchor/trust-anchor.env — defaults there match this).
#
# You do NOT need to create .env at all for a standard local try-it-out.
# The defaults below are the ones used out of the box.

# ---------------------------------------------------------------------------
# SERVER (Trust Anchor)
# ---------------------------------------------------------------------------

# Network bind
TRUST_ANCHOR_HOST=0.0.0.0
TRUST_ANCHOR_PORT=8000

# Redis connection string used by the server for tool storage
REDIS_URL=redis://localhost:6379/0

# Where the server reads/writes its RSA keypair. In Docker these live on a
# named volume (trust-anchor-keys); native installs use /opt/trust-anchor/keys.
PRIVATE_KEY_PATH=/opt/trust-anchor/keys/private.pem
PUBLIC_KEY_PATH=/opt/trust-anchor/keys/public.pem

# Comma-separated list of API keys accepted by the publisher API.
# CHANGE THIS before exposing Trust Anchor anywhere beyond localhost.
PUBLISHER_KEYS=dev-publisher-key

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# CLIENT (MCP bridge — used by Claude Code / Claude Desktop / VS Code Copilot)
# ---------------------------------------------------------------------------
# These are read by the MCP bridge, not the server. The client bootstrap
# scripts write them into the generated MCP config for you; you only need
# to set them here if you're running the bridge manually.

# Where the client fetches tools from
# TRUST_ANCHOR_URL=http://localhost:8000

# Directory holding *_credentials.yaml files for target devices.
# Never committed to git. See scripts/sample_credentials.yaml.example.
# CREDENTIAL_PATH=~/.config/mcp
